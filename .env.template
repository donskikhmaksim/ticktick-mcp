# === TickTick Open API (official, OAuth) ===
# Register an app at https://developer.ticktick.com to get these.
TICKTICK_CLIENT_ID=your_client_id_here
TICKTICK_CLIENT_SECRET=your_client_secret_here

# Populated automatically by 'uv run -m ticktick_mcp.cli auth' (local OAuth flow).
# On Railway, paste the access token here as an environment variable instead.
TICKTICK_ACCESS_TOKEN=
TICKTICK_REFRESH_TOKEN=

# === Unofficial v2 API (optional) ===
# Enables tags, completed-task history, Inbox reads, and moving tasks between
# lists. Auth = the `t` cookie from a logged-in ticktick.com browser session
# (DevTools → Application → Cookies → ticktick.com → copy value of `t`).
# Do NOT use username/password: TickTick gates signon behind a captcha.
# Leave blank to disable. The token is long-lived but expires — re-extract then.
TICKTICK_V2_TOKEN=

# === Transport / deployment ===
# Local: leave as stdio (default). Railway/remote: set to streamable-http.
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
# Railway injects PORT automatically; only set MCP_PORT for local HTTP testing.
MCP_PORT=8000
# Unguessable secret appended to the URL path (/mcp/<secret>) as lightweight
# auth for the public endpoint. Generate with: openssl rand -hex 24
MCP_SECRET=

# IANA timezone used when interpreting/formatting task due dates
# (e.g. Europe/Moscow, America/New_York). Defaults to UTC if unset.
USER_TIMEZONE=

# URL of the shared OAuth proxy used by the self-service /setup/<MCP_SECRET>
# flow. Leave unset to use the default hosted proxy.
TICKTICK_OAUTH_PROXY_URL=
